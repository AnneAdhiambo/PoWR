# ============================================================
# PoWR Backend — Environment Variables
# Copy to .env and fill in your values.
# Never commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=3001
NODE_ENV=development

# URL of the running frontend (used for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:3000

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/powr

# ------------------------------------------------------------
# GitHub OAuth
# ------------------------------------------------------------
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
# Must match the callback URL registered in your GitHub OAuth App
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# ------------------------------------------------------------
# Stacks / Blockchain
# ------------------------------------------------------------

# Network: devnet | testnet | mainnet
STACKS_NETWORK=devnet

# Private key of the oracle wallet that signs contract calls (hex, no 0x prefix)
STACKS_ORACLE_PRIVATE_KEY=

# Stacks address that corresponds to STACKS_ORACLE_PRIVATE_KEY
STACKS_ORACLE_ADDRESS=

# Deployed powr-registry contract address (e.g. ST1PQHQKV0RJXZFY1DGX8MNSNYVE3VGZJSRTPGZGM)
POWR_REGISTRY_CONTRACT_ADDRESS=

# Local Clarinet devnet node (leave as-is for devnet)
STACKS_NODE_URL=http://localhost:20443

# Stacks API (Hiro Platform or local devnet)
STACKS_API_URL=http://localhost:3999

# Hiro Platform API key — get one at https://platform.hiro.so
# Required for mainnet/testnet; optional for devnet
HIRO_API_KEY=

# ------------------------------------------------------------
# AI Analysis (pick one — priority order: Gemini > AgentRouter > OpenAI > Anthropic)
# ------------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OR: Anthropic via AgentRouter
AGENT_ROUTER_API_KEY=
AGENT_ROUTER_MODEL=claude-haiku-4-5-20251001

# OR: OpenAI
OPENAI_API_KEY=

# OR: Anthropic direct
ANTHROPIC_API_KEY=

# ------------------------------------------------------------
# Payments (legacy — Base Sepolia; may be removed in future)
# ------------------------------------------------------------
PAYMENT_WALLET_ADDRESS=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
SEPOLIA_RPC_URL=https://rpc.sepolia.org
