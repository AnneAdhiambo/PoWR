# ============================================================
# PoWR Frontend (Next.js) — Environment Variables
# Copy to .env.local and fill in your values.
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Never commit .env.local to source control.
# ============================================================

# ------------------------------------------------------------
# Backend API
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001

# ------------------------------------------------------------
# Stacks / Blockchain
# ------------------------------------------------------------

# Network: devnet | testnet | mainnet
NEXT_PUBLIC_STACKS_NETWORK=devnet

# Deployed powr-registry contract address
NEXT_PUBLIC_POWR_REGISTRY_CONTRACT_ADDRESS=

# Stacks node RPC URL (leave as-is for local Clarinet devnet)
NEXT_PUBLIC_STACKS_NODE_URL=http://localhost:20443

# Hiro Platform API key — get one at https://platform.hiro.so
# Required for mainnet/testnet; optional for devnet
NEXT_PUBLIC_HIRO_API_KEY=

# STX address that receives subscription payments
NEXT_PUBLIC_PAYMENT_WALLET_ADDRESS=
